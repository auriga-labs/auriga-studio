    { "id": "layout", "label": "レイアウト", "mnemonic": "L", "items": [] },
    { "id": "tools",  "label": "ツール",     "mnemonic": "T", "items": [] },
    { "id": "help",   "label": "ヘルプ",     "mnemonic": "H", "items": [] }
